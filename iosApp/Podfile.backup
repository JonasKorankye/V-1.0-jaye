platform :ios, '14.0'

# Use newer versions that have BoringSSL fixes
# Force update to avoid -G flag issue
source 'https://cdn.cocoapods.org/'

# CocoaPods configuration
# Removed :generate_multiple_pod_projects to ensure workspace is created properly

target 'iosApp' do
  use_frameworks! :linkage => :static
  use_modular_headers!
  
  # Firebase dependencies - MUST match what GitLive libraries expect
  # GitLive libraries are just wrappers around these native iOS SDKs
  pod 'FirebaseCore', '~> 11.0'
  pod 'FirebaseAuth', '~> 11.0'
  pod 'FirebaseFirestore', '~> 11.0'
  pod 'FirebaseFunctions', '~> 11.0'
  pod 'FirebaseStorage', '~> 11.0'
  pod 'FirebaseCrashlytics', '~> 11.0'
  pod 'FirebaseMessaging', '~> 11.0'  # Required by GitLive cinterop definitions
  
  # Google Sign-In (if used)
  pod 'GoogleSignIn', '~> 8.0'
  
  # Note: Kotlin frameworks (data, shared, ComposeApp) are linked directly via Xcode
  # Not using CocoaPods for Kotlin frameworks to avoid Ruby dependency issues
  
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      
      # Fix product name if empty
      if config.build_settings['PRODUCT_NAME'].nil? || config.build_settings['PRODUCT_NAME'].empty?
        config.build_settings['PRODUCT_NAME'] = 'FlipVerse'
      end
      
      # Fix BoringSSL-GRPC compilation issue for iOS simulator
      # This is a comprehensive fix for the -G flag issue in Xcode 16.4
      if target.name == 'BoringSSL-GRPC'
        puts "🔧 Fixing BoringSSL-GRPC build settings..."
        
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'OPENSSL_NO_ASM=1'
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        
        # Clear all potentially problematic flags
        config.build_settings['OTHER_CFLAGS'] = ['$(inherited)']
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = ['$(inherited)']
        config.build_settings['WARNING_CFLAGS'] = ['$(inherited)']
        
        # Remove assembly and set C standard
        config.build_settings['GCC_C_LANGUAGE_STANDARD'] = 'gnu11'
      end
      
      # Fix for gRPC-Core if needed
      if target.name == 'gRPC-Core'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'GRPC_CFSTREAM=1'
      end
    end
    
    # Additional fix: Modify BoringSSL source compilation flags directly
    if target.name == 'BoringSSL-GRPC'
      puts "🔧 Applying per-file compiler flags for BoringSSL-GRPC..."
      target.source_build_phase.files.each do |build_file|
        if build_file.file_ref && build_file.file_ref.path
          # Disable all problematic flags for C/C++ files
          if build_file.file_ref.path.end_with?('.c', '.cc', '.cpp')
            build_file.settings = { 
              'COMPILER_FLAGS' => '-w -Wno-everything',
              'GCC_OPTIMIZATION_LEVEL' => '0'
            }
          end
        end
      end
    end
    
    # Nuclear option: Use -Wno-error to demote errors to warnings
    if target.name.start_with?('BoringSSL', 'gRPC')
      puts "🔧 Setting warning-tolerant build settings for #{target.name}..."
      target.build_configurations.each do |config|
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['CLANG_WARN_STRICT_PROTOTYPES'] = 'NO'
      end
    end
  end
  
  # Fix product name in main target
  installer.generated_projects.each do |project|
    project.targets.each do |target|
      target.build_configurations.each do |config|
        if target.name == 'iosApp'
          config.build_settings['PRODUCT_NAME'] = 'FlipVerse'
          config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = 'com.flipverse.iosApp'
        end
      end
    end
  end
end
